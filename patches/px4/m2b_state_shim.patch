+		angular_velocity.xyz[1] += _param_m2b_g_y.get();
+		angular_velocity.xyz[2] += _param_m2b_g_z.get();
+
+	} else if (profile == M2B_PROFILE_NOISE) {
+		angular_velocity.xyz[0] += _param_m2b_g_x.get() * m2bNoise(_m2b_noise_state, _param_m2b_seed.get());
+		angular_velocity.xyz[1] += _param_m2b_g_y.get() * m2bNoise(_m2b_noise_state, _param_m2b_seed.get());
+		angular_velocity.xyz[2] += _param_m2b_g_z.get() * m2bNoise(_m2b_noise_state, _param_m2b_seed.get());
+
+	} else if (profile == M2B_PROFILE_NAN || profile == M2B_PROFILE_INF) {
+		for (int axis = 0; axis < 3; axis++) {
+			if (m2bAxisSelected(_param_m2b_g_x.get(), _param_m2b_g_y.get(), _param_m2b_g_z.get(), axis)) {
+				angular_velocity.xyz[axis] = (profile == M2B_PROFILE_NAN) ? NAN : INFINITY;
+			}
+		}
+	}
+}
