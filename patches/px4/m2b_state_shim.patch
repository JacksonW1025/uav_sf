+namespace
+{
+static constexpr int M2B_PROFILE_DELAY = 1;
+static constexpr int M2B_PROFILE_BIAS = 2;
+static constexpr int M2B_PROFILE_NOISE = 3;
+static constexpr int M2B_PROFILE_NAN = 4;
+static constexpr int M2B_PROFILE_INF = 5;
+
+bool m2bShimActive(const bool enabled, const float start_s, const float end_s, const hrt_abstime now)
+{
+	if (!enabled) {
+		return false;
+	}
+
+	const float now_s = static_cast<float>(now) * 1e-6f;
+	return (now_s >= start_s) && ((end_s <= 0.f) || (now_s <= end_s));
+}
+
+bool m2bAxisSelected(const float x, const float y, const float z, const int axis)
+{
+	const bool any_axis = (fabsf(x) > FLT_EPSILON) || (fabsf(y) > FLT_EPSILON) || (fabsf(z) > FLT_EPSILON);
+
+	if (!any_axis) {
+		return true;
+	}
+
+	const float values[3] {x, y, z};
+	return fabsf(values[axis]) > FLT_EPSILON;
+}
+
+float m2bNoise(uint32_t &state, const int32_t seed)
+{
+	if (state == 0) {
+		state = static_cast<uint32_t>(seed) ^ 0x85ebca6bu;
+	}
+
+	state = 1664525u * state + 1013904223u;
+	const float uniform_0_1 = static_cast<float>((state >> 8) & 0x00ffffffu) * (1.f / 16777216.f);
+	return 2.f * uniform_0_1 - 1.f;
+}
+
+} // namespace
+
+void VehicleAngularVelocity::ApplyM2BGyroShim(vehicle_angular_velocity_s &angular_velocity)
+{
+	_m2b_gyro_buffer[_m2b_gyro_buffer_index].timestamp_sample = angular_velocity.timestamp_sample;
+
+	for (int i = 0; i < 3; i++) {
+		_m2b_gyro_buffer[_m2b_gyro_buffer_index].xyz[i] = angular_velocity.xyz[i];
+	}
+
+	_m2b_gyro_buffer_index = (_m2b_gyro_buffer_index + 1) % M2B_BUFFER_LEN;
+
+	if (!m2bShimActive(_param_m2b_en.get(), _param_m2b_start.get(), _param_m2b_end.get(), hrt_absolute_time())) {
+		return;
+	}
+
+	const int profile = _param_m2b_g_prof.get();
+
+	if (profile == M2B_PROFILE_DELAY) {
+		const int32_t delay_ms = _param_m2b_g_dly.get();
+		const uint64_t delay_us = static_cast<uint64_t>(delay_ms > 0 ? delay_ms : 0) * 1000ULL;
+		const uint64_t target_time = (angular_velocity.timestamp_sample > delay_us) ? angular_velocity.timestamp_sample - delay_us : 0;
+		bool found = false;
+		uint64_t best_time = 0;
+		float delayed[3] {};
+
+		for (const M2BVectorSample &sample : _m2b_gyro_buffer) {
+			if ((sample.timestamp_sample != 0) && (sample.timestamp_sample <= target_time) && (sample.timestamp_sample >= best_time)) {
+				best_time = sample.timestamp_sample;
+
+				for (int i = 0; i < 3; i++) {
