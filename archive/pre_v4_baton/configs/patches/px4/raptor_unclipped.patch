# raptor_unclipped.patch
# Purpose: create the raptor_unclipped SUT by bypassing mc_raptor observe() input clipping.
# Source file: src/modules/mc_raptor/mc_raptor.cpp.
# Original semantics: position error components were clipped to +/- max_position_error (0.5),
# and linear velocity error components were clipped to +/- max_velocity_error (1.0).
# New semantics: the target-frame position and velocity errors are passed to the policy
# unchanged, so raptor_input can exceed the old 0.5 m and 1.0 m/s observation bounds.
diff --git a/src/modules/mc_raptor/mc_raptor.cpp b/src/modules/mc_raptor/mc_raptor.cpp
index d8b98c7503..030d5c45e6 100644
--- a/src/modules/mc_raptor/mc_raptor.cpp
+++ b/src/modules/mc_raptor/mc_raptor.cpp
@@ -385,9 +385,9 @@ void Raptor::observe(rl_tools::inference::applications::l2f::Observation<EXECUTO
 		p[1] = -(position[1] - _trajectory_setpoint.position[1]);
 		p[2] = -(position[2] - _trajectory_setpoint.position[2]);
 		rotate_vector(Rt_inv, p, pt); // The position and velocity error are in the target frame
-		observation.position[0] = clip(pt[0], max_position_error, -max_position_error);
-		observation.position[1] = clip(pt[1], max_position_error, -max_position_error);
-		observation.position[2] = clip(pt[2], max_position_error, -max_position_error);
+		observation.position[0] = pt[0];
+		observation.position[1] = pt[1];
+		observation.position[2] = pt[2];
 	}
 	{
 		// Linear Velocity
@@ -396,9 +396,9 @@ void Raptor::observe(rl_tools::inference::applications::l2f::Observation<EXECUTO
 		v[1] = -(linear_velocity[1] - _trajectory_setpoint.velocity[1]);
 		v[2] = -(linear_velocity[2] - _trajectory_setpoint.velocity[2]);
 		rotate_vector(Rt_inv, v, vt);
-		observation.linear_velocity[0] = clip(vt[0], max_velocity_error, -max_velocity_error);
-		observation.linear_velocity[1] = clip(vt[1], max_velocity_error, -max_velocity_error);
-		observation.linear_velocity[2] = clip(vt[2], max_velocity_error, -max_velocity_error);
+		observation.linear_velocity[0] = vt[0];
+		observation.linear_velocity[1] = vt[1];
+		observation.linear_velocity[2] = vt[2];
 	}
 	{
 		// Angular Velocity
