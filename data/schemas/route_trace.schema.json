{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://uav-sf.local/schemas/route_trace.schema.json",
  "title": "PX4 route transition trace event",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "run_id",
    "timestamp",
    "timestamp_domain",
    "event_type",
    "declared_mode",
    "registration_state",
    "authority_source",
    "producer_identity",
    "setpoint_level",
    "behavior_phase",
    "setpoint_topic",
    "message_age",
    "enabled_modules",
    "bypassed_modules",
    "allocator_input",
    "actuator_writer",
    "actuator_output_summary",
    "failsafe_state",
    "fallback_target",
    "observation",
    "evidence_source",
    "confidence"
  ],
  "properties": {
    "schema_version": {"const": "1.1"},
    "run_id": {"type": "string", "minLength": 1},
    "timestamp": {"type": "number", "minimum": 0},
    "timestamp_domain": {
      "enum": ["px4_boot_us", "px4_uorb_us", "ros_node_ns", "dds_receive_ns", "sim_time_ns", "wall_clock_ns", "ulog_us"]
    },
    "event_type": {"type": "string", "minLength": 1},
    "declared_mode": {"type": ["string", "integer", "null"]},
    "registration_state": {"type": ["string", "object", "null"]},
    "authority_source": {"type": ["string", "null"]},
    "producer_identity": {"type": ["string", "null"]},
    "setpoint_level": {
      "enum": [
        "position",
        "velocity",
        "acceleration",
        "position_velocity",
        "position_velocity_acceleration",
        "attitude",
        "body_rate",
        "thrust_and_torque",
        "direct_actuator",
        "unknown"
      ]
    },
    "behavior_phase": {"type": ["string", "null"]},
    "setpoint_topic": {"type": ["string", "null"]},
    "message_age": {"type": ["number", "null"], "minimum": 0},
    "enabled_modules": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
    "bypassed_modules": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
    "allocator_input": {"type": ["string", "object", "null"]},
    "actuator_writer": {"type": ["string", "object", "null"]},
    "actuator_output_summary": {"type": ["object", "null"]},
    "failsafe_state": {"type": ["string", "object", "boolean", "null"]},
    "fallback_target": {"type": ["string", "integer", "null"]},
    "observation": {
      "oneOf": [
        {"type": "null"},
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "sequence",
            "event_id",
            "source_id",
            "topic_id",
            "writer_id",
            "instance",
            "profile",
            "expected_period_us",
            "subject_timestamp"
          ],
          "properties": {
            "sequence": {"type": "integer", "minimum": 0},
            "event_id": {"type": "integer", "minimum": 0},
            "source_id": {"type": "integer", "minimum": 0},
            "topic_id": {"type": "integer", "minimum": 0},
            "writer_id": {"type": "integer", "minimum": 0},
            "instance": {"type": "integer", "minimum": 0},
            "profile": {"enum": ["BASELINE", "TRANSITION", "UNKNOWN"]},
            "expected_period_us": {"type": "integer", "minimum": 0},
            "subject_timestamp": {"type": "number", "minimum": 0}
          }
        }
      ]
    },
    "evidence_source": {"type": "string", "minLength": 1},
    "confidence": {"enum": ["HIGH", "MEDIUM", "LOW", "UNKNOWN"]}
  }
}
