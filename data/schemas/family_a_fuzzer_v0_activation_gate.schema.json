{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://uav-sf.local/schemas/family_a_fuzzer_v0_activation_gate.schema.json",
  "title": "Family A Fuzzer v0 preregistration activation gate",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "gate_id",
    "status",
    "preregistration_complete",
    "source_lock_complete",
    "seed_catalog_complete",
    "state_model_complete",
    "event_grammar_complete",
    "mutation_grammar_complete",
    "strategy_matrix_complete",
    "budgets_frozen",
    "oracle_identity_complete",
    "evidence_rules_complete",
    "safety_rules_complete",
    "analysis_plan_complete",
    "consistency_check_passed",
    "focused_tests_passed",
    "validate_repo_passed",
    "campaign_activated",
    "runtime_authorized",
    "formal_attempts_authorized",
    "authorized_family",
    "excluded_scopes",
    "activation_requires_separate_commit",
    "activation_requires_explicit_review",
    "activation_blockers",
    "next_exact_action"
  ],
  "properties": {
    "schema_version": {"const": "1.0"},
    "gate_id": {"const": "FAMILY_A_FUZZER_V0_ACTIVATION_GATE"},
    "status": {"const": "PREREGISTERED_NOT_ACTIVATED"},
    "preregistration_complete": {"type": "boolean"},
    "source_lock_complete": {"type": "boolean"},
    "seed_catalog_complete": {"type": "boolean"},
    "state_model_complete": {"type": "boolean"},
    "event_grammar_complete": {"type": "boolean"},
    "mutation_grammar_complete": {"type": "boolean"},
    "strategy_matrix_complete": {"type": "boolean"},
    "budgets_frozen": {"type": "boolean"},
    "oracle_identity_complete": {"type": "boolean"},
    "evidence_rules_complete": {"type": "boolean"},
    "safety_rules_complete": {"type": "boolean"},
    "analysis_plan_complete": {"type": "boolean"},
    "consistency_check_passed": {"type": "boolean"},
    "focused_tests_passed": {"type": "boolean"},
    "validate_repo_passed": {"type": "boolean"},
    "campaign_activated": {"const": false},
    "runtime_authorized": {"const": false},
    "formal_attempts_authorized": {"const": false},
    "authorized_family": {"const": "FAMILY_A_ONLY"},
    "excluded_scopes": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {"type": "string", "minLength": 1}
    },
    "activation_requires_separate_commit": {"const": true},
    "activation_requires_explicit_review": {"const": true},
    "activation_blockers": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {"type": "string", "minLength": 1}
    },
    "next_exact_action": {
      "const": "review the frozen Family A Fuzzer v0 preregistration and create a separate activation decision"
    }
  }
}
