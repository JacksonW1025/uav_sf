{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://uav-sf.local/schemas/successor_lifecycle_event.schema.json",
  "title": "External-mode successor lifecycle observation",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "run_id",
    "event_type",
    "ros_time_ns",
    "monotonic_ns",
    "px4_timestamp_us",
    "active_mode",
    "nav_state_user_intention",
    "executor_in_charge",
    "arming_state",
    "armed",
    "landed",
    "failsafe",
    "registered_mode_id",
    "registered_executor_id",
    "owned_mode",
    "details"
  ],
  "properties": {
    "schema_version": {"const": "1.0"},
    "run_id": {"type": "string", "minLength": 1},
    "event_type": {
      "enum": [
        "monitor_started",
        "clock_bridge_sample",
        "registration_observed",
        "vehicle_status_observed",
        "mode_completed_observed",
        "executor_command_observed",
        "land_detected_observed",
        "monitor_finished"
      ]
    },
    "ros_time_ns": {"type": "integer", "minimum": 0},
    "monotonic_ns": {"type": "integer", "minimum": 0},
    "px4_timestamp_us": {"type": ["integer", "null"], "minimum": 0},
    "active_mode": {"type": ["integer", "null"], "minimum": 0},
    "nav_state_user_intention": {"type": ["integer", "null"], "minimum": 0},
    "executor_in_charge": {"type": ["integer", "null"], "minimum": 0},
    "arming_state": {"type": ["integer", "null"], "minimum": 0},
    "armed": {"type": ["boolean", "null"]},
    "landed": {"type": ["boolean", "null"]},
    "failsafe": {"type": ["boolean", "null"]},
    "registered_mode_id": {"type": ["integer", "null"], "minimum": 0},
    "registered_executor_id": {"type": ["integer", "null"], "minimum": 0},
    "owned_mode": {"type": ["integer", "null"], "minimum": 0},
    "details": {"type": "object"},
    "px4_outbound_timestamp_us": {"type": "integer", "minimum": 0},
    "px4_boot_timestamp_us": {"type": "integer", "minimum": 0},
    "ros_receive_ns": {"type": "integer", "minimum": 0},
    "monotonic_receive_ns": {"type": "integer", "minimum": 0},
    "timesync_source_protocol": {"type": "integer", "minimum": 0},
    "timesync_estimated_offset_us": {"type": "integer"},
    "timesync_round_trip_time_us": {"type": "integer", "minimum": 0},
    "timesync_converged": {"type": "boolean"}
  }
}
