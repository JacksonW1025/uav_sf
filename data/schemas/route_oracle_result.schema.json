{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://uav-sf.local/schemas/route_oracle_result.schema.json",
  "title": "Route Oracle v0.4 result",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "route_oracle_version",
    "run_id",
    "observation_kind",
    "status",
    "violation_categories",
    "transition",
    "retained_route",
    "clock_bridge",
    "clauses",
    "ground_truth_case_id",
    "oracle_validation_profile",
    "threshold_profile_id",
    "evidence_completeness"
  ],
  "properties": {
    "schema_version": {"const": "1.3"},
    "route_oracle_version": {"const": "0.4"},
    "run_id": {"type": "string", "minLength": 1},
    "observation_kind": {"enum": ["TRANSITION", "RETAINED_ROUTE"]},
    "status": {"enum": ["PASS", "VIOLATION", "UNKNOWN", "NOT_APPLICABLE"]},
    "violation_categories": {
      "type": "array",
      "items": {
        "enum": [
          "UNEXPECTED_FALLBACK",
          "UNEXPECTED_ROUTE_CHANGE",
          "ROUTE_RETENTION_GAP",
          "AUTHORITY_CONFLICT",
          "WRITER_CONFLICT",
          "STALE_OR_INSUFFICIENT_EVIDENCE"
        ]
      },
      "uniqueItems": true
    },
    "transition": {
      "type": ["object", "null"],
      "additionalProperties": true
    },
    "retained_route": {
      "type": ["object", "null"],
      "additionalProperties": true
    },
    "clock_bridge": {
      "type": ["object", "null"],
      "additionalProperties": true
    },
    "ground_truth_case_id": {"type": ["string", "null"]},
    "oracle_validation_profile": {"type": "string", "minLength": 1},
    "threshold_profile_id": {"type": "string", "minLength": 1},
    "evidence_completeness": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_artifact",
        "critical_window",
        "writer_sequence",
        "candidate_writer_coverage",
        "clock_bridge",
        "route_epoch"
      ],
      "properties": {
        "source_artifact": {"enum": ["COMPLETE", "INCOMPLETE", "UNKNOWN"]},
        "critical_window": {"enum": ["COMPLETE", "BOUNDED", "INSUFFICIENT", "NOT_APPLICABLE"]},
        "writer_sequence": {"enum": ["COMPLETE", "INCOMPLETE", "UNKNOWN", "NOT_APPLICABLE"]},
        "candidate_writer_coverage": {"enum": ["COMPLETE", "INCOMPLETE", "UNKNOWN", "NOT_APPLICABLE"]},
        "clock_bridge": {"enum": ["VALID", "INVALID", "MISSING", "NOT_REQUIRED"]},
        "route_epoch": {"enum": ["COMPLETE", "INCOMPLETE", "UNKNOWN", "NOT_APPLICABLE"]}
      }
    },
    "clauses": {
      "type": "object",
      "additionalProperties": false,
      "required": ["revocation", "installation", "exclusivity", "continuity", "recovery"],
      "properties": {
        "revocation": {"$ref": "#/$defs/clause"},
        "installation": {"$ref": "#/$defs/clause"},
        "exclusivity": {"$ref": "#/$defs/clause"},
        "continuity": {"$ref": "#/$defs/clause"},
        "recovery": {"$ref": "#/$defs/clause"}
      }
    }
  },
  "$defs": {
    "clause": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "metrics", "evidence", "reasons"],
      "properties": {
        "status": {"enum": ["PASS", "VIOLATION", "UNKNOWN", "NOT_APPLICABLE"]},
        "metrics": {"type": "object"},
        "evidence": {"type": "array", "items": {"type": "object"}},
        "reasons": {"type": "array", "items": {"type": "string"}}
      }
    }
  }
}
