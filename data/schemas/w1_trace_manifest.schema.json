{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://uav-sf.local/schemas/w1_trace_manifest.schema.json",
  "title": "W1 deterministic trace manifest",
  "type": "object",
  "required": [
    "schema_version",
    "status",
    "workload",
    "dependencies",
    "source_artifact_hashes",
    "rosbag_sha256",
    "ulog_sha256",
    "topics",
    "start_timestamp_ns",
    "end_timestamp_ns",
    "clock_domains",
    "clock_bridge_valid_intervals",
    "expected_lifecycle_edges",
    "expected_route_replacements",
    "expected_non_route_task_transitions",
    "expected_setpoint",
    "bounds",
    "cleanup_expectation",
    "source_trace_id",
    "canonical_replay_ids"
  ],
  "properties": {
    "schema_version": {"const": "1.0"},
    "status": {"enum": ["ACCEPTED_SOURCE_TRACE", "UNAVAILABLE_NO_ACCEPTED_SOURCE_TRACE"]},
    "workload": {"type": "object"},
    "dependencies": {"type": "object"},
    "source_artifact_hashes": {"type": "object"},
    "rosbag_sha256": {"type": ["string", "null"]},
    "ulog_sha256": {"type": ["string", "null"]},
    "topics": {"type": "array"},
    "start_timestamp_ns": {"type": ["integer", "null"]},
    "end_timestamp_ns": {"type": ["integer", "null"]},
    "clock_domains": {"type": "object"},
    "clock_bridge_valid_intervals": {"type": "array"},
    "expected_lifecycle_edges": {"type": "array"},
    "expected_route_replacements": {"type": "array"},
    "expected_non_route_task_transitions": {"type": "array"},
    "expected_setpoint": {"type": "object"},
    "bounds": {"type": "object"},
    "cleanup_expectation": {"type": "object"},
    "source_trace_id": {"type": ["string", "null"]},
    "canonical_replay_ids": {"type": "array"}
  },
  "additionalProperties": true
}
