+void VehicleAngularVelocity::ApplyM2BGyroShim(vehicle_angular_velocity_s &angular_velocity)
+{
+	_m2b_gyro_buffer[_m2b_gyro_buffer_index].timestamp_sample = angular_velocity.timestamp_sample;
+
+	for (int i = 0; i < 3; i++) {
+		_m2b_gyro_buffer[_m2b_gyro_buffer_index].xyz[i] = angular_velocity.xyz[i];
+	}
+
+	_m2b_gyro_buffer_index = (_m2b_gyro_buffer_index + 1) % M2B_BUFFER_LEN;
+
+	if (!m2bShimActive(_param_m2b_en.get(), _param_m2b_start.get(), _param_m2b_end.get(), hrt_absolute_time())) {
+		return;
+	}
+
+	const int profile = _param_m2b_g_prof.get();
+
+	if (profile == M2B_PROFILE_DELAY) {
+		const int32_t delay_ms = _param_m2b_g_dly.get();
+		const uint64_t delay_us = static_cast<uint64_t>(delay_ms > 0 ? delay_ms : 0) * 1000ULL;
+		const uint64_t target_time = (angular_velocity.timestamp_sample > delay_us) ? angular_velocity.timestamp_sample - delay_us : 0;
+		bool found = false;
+		uint64_t best_time = 0;
+		float delayed[3] {};
+
+		for (const M2BVectorSample &sample : _m2b_gyro_buffer) {
+			if ((sample.timestamp_sample != 0) && (sample.timestamp_sample <= target_time) && (sample.timestamp_sample >= best_time)) {
+				best_time = sample.timestamp_sample;
+
+				for (int i = 0; i < 3; i++) {
+					delayed[i] = sample.xyz[i];
+				}
+
+				found = true;
+			}
+		}
+
+		if (found) {
+			for (int i = 0; i < 3; i++) {
+				angular_velocity.xyz[i] = delayed[i];
+			}
+		}
+
+	} else if (profile == M2B_PROFILE_BIAS) {
+		angular_velocity.xyz[0] += _param_m2b_g_x.get();
+		angular_velocity.xyz[1] += _param_m2b_g_y.get();
+		angular_velocity.xyz[2] += _param_m2b_g_z.get();
