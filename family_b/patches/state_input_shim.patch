+
+	} else if (profile == M2B_PROFILE_NOISE) {
+		local_position.x += _param_m2b_p_x.get() * m2bNoise(_m2b_noise_state, _param_m2b_seed.get());
+		local_position.y += _param_m2b_p_y.get() * m2bNoise(_m2b_noise_state, _param_m2b_seed.get());
+		local_position.z += _param_m2b_p_z.get() * m2bNoise(_m2b_noise_state, _param_m2b_seed.get());
+
+	} else if (profile == M2B_PROFILE_NAN || profile == M2B_PROFILE_INF) {
+		float *values[3] {&local_position.x, &local_position.y, &local_position.z};
+
+		for (int axis = 0; axis < 3; axis++) {
+			if (m2bAxisSelected(_param_m2b_p_x.get(), _param_m2b_p_y.get(), _param_m2b_p_z.get(), axis)) {
+				*values[axis] = (profile == M2B_PROFILE_NAN) ? NAN : INFINITY;
+			}
+		}
+	}
+}
+
+void EKF2Selector::ApplyM2BVelocityShim(vehicle_local_position_s &local_position)
+{
+	_m2b_velocity_buffer[_m2b_velocity_buffer_index].timestamp_sample = local_position.timestamp_sample;
+	_m2b_velocity_buffer[_m2b_velocity_buffer_index].xyz[0] = local_position.vx;
+	_m2b_velocity_buffer[_m2b_velocity_buffer_index].xyz[1] = local_position.vy;
+	_m2b_velocity_buffer[_m2b_velocity_buffer_index].xyz[2] = local_position.vz;
+	_m2b_velocity_buffer_index = (_m2b_velocity_buffer_index + 1) % M2B_BUFFER_LEN;
+
+	if (!m2bShimActive(_param_m2b_en.get(), _param_m2b_start.get(), _param_m2b_end.get(), hrt_absolute_time())) {
+		return;
+	}
+
+	const int profile = _param_m2b_v_prof.get();
+
+	if (profile == M2B_PROFILE_DELAY) {
+		const int32_t delay_ms = _param_m2b_v_dly.get();
+		const uint64_t delay_us = static_cast<uint64_t>(delay_ms > 0 ? delay_ms : 0) * 1000ULL;
+		const uint64_t target_time = (local_position.timestamp_sample > delay_us) ? local_position.timestamp_sample - delay_us : 0;
+		bool found = false;
+		uint64_t best_time = 0;
+		float delayed[3] {};
+
+		for (const M2BVectorSample &sample : _m2b_velocity_buffer) {
+			if ((sample.timestamp_sample != 0) && (sample.timestamp_sample <= target_time) && (sample.timestamp_sample >= best_time)) {
+				best_time = sample.timestamp_sample;
+				delayed[0] = sample.xyz[0];
+				delayed[1] = sample.xyz[1];
+				delayed[2] = sample.xyz[2];
+				found = true;
+			}
+		}
+
+		if (found) {
+			local_position.vx = delayed[0];
+			local_position.vy = delayed[1];
+			local_position.vz = delayed[2];
+		}
+
+	} else if (profile == M2B_PROFILE_BIAS) {
+		local_position.vx += _param_m2b_v_x.get();
+		local_position.vy += _param_m2b_v_y.get();
+		local_position.vz += _param_m2b_v_z.get();
+
+	} else if (profile == M2B_PROFILE_NOISE) {
+		local_position.vx += _param_m2b_v_x.get() * m2bNoise(_m2b_noise_state, _param_m2b_seed.get());
+		local_position.vy += _param_m2b_v_y.get() * m2bNoise(_m2b_noise_state, _param_m2b_seed.get());
+		local_position.vz += _param_m2b_v_z.get() * m2bNoise(_m2b_noise_state, _param_m2b_seed.get());
+
+	} else if (profile == M2B_PROFILE_NAN || profile == M2B_PROFILE_INF) {
+		float *values[3] {&local_position.vx, &local_position.vy, &local_position.vz};
+
+		for (int axis = 0; axis < 3; axis++) {
+			if (m2bAxisSelected(_param_m2b_v_x.get(), _param_m2b_v_y.get(), _param_m2b_v_z.get(), axis)) {
+				*values[axis] = (profile == M2B_PROFILE_NAN) ? NAN : INFINITY;
+			}
+		}
+	}
+}
+
+void EKF2Selector::ApplyM2BAttitudeShim(vehicle_attitude_s &attitude)
+{
+	_m2b_attitude_buffer[_m2b_attitude_buffer_index].timestamp_sample = attitude.timestamp_sample;
+
+	for (int i = 0; i < 4; i++) {
+		_m2b_attitude_buffer[_m2b_attitude_buffer_index].q[i] = attitude.q[i];
+	}
+
+	_m2b_attitude_buffer_index = (_m2b_attitude_buffer_index + 1) % M2B_BUFFER_LEN;
+
+	if (!m2bShimActive(_param_m2b_en.get(), _param_m2b_start.get(), _param_m2b_end.get(), hrt_absolute_time())) {
+		return;
+	}
+
+	const int profile = _param_m2b_a_prof.get();
+
+	if (profile == M2B_PROFILE_DELAY) {
+		const int32_t delay_ms = _param_m2b_a_dly.get();
+		const uint64_t delay_us = static_cast<uint64_t>(delay_ms > 0 ? delay_ms : 0) * 1000ULL;
+		const uint64_t target_time = (attitude.timestamp_sample > delay_us) ? attitude.timestamp_sample - delay_us : 0;
+		bool found = false;
+		uint64_t best_time = 0;
+		float delayed[4] {};
+
+		for (const M2BAttitudeSample &sample : _m2b_attitude_buffer) {
+			if ((sample.timestamp_sample != 0) && (sample.timestamp_sample <= target_time) && (sample.timestamp_sample >= best_time)) {
+				best_time = sample.timestamp_sample;
+
+				for (int i = 0; i < 4; i++) {
+					delayed[i] = sample.q[i];
+				}
+
+				found = true;
+			}
+		}
+
+		if (found) {
+			for (int i = 0; i < 4; i++) {
+				attitude.q[i] = delayed[i];
+			}
+		}
+
+	} else if (profile == M2B_PROFILE_BIAS || profile == M2B_PROFILE_NOISE) {
+		float roll = _param_m2b_a_r.get();
+		float pitch = _param_m2b_a_p.get();
+		float yaw = _param_m2b_a_y.get();
+
+		if (profile == M2B_PROFILE_NOISE) {
+			roll *= m2bNoise(_m2b_noise_state, _param_m2b_seed.get());
+			pitch *= m2bNoise(_m2b_noise_state, _param_m2b_seed.get());
+			yaw *= m2bNoise(_m2b_noise_state, _param_m2b_seed.get());
+		}
+
+		Quatf q_out = (Quatf(attitude.q) * Quatf(matrix::Eulerf(roll, pitch, yaw))).normalized();
+		q_out.copyTo(attitude.q);
+
+	} else if (profile == M2B_PROFILE_NAN || profile == M2B_PROFILE_INF) {
+		const bool any_axis = (fabsf(_param_m2b_a_r.get()) > FLT_EPSILON) || (fabsf(_param_m2b_a_p.get()) > FLT_EPSILON)
+				      || (fabsf(_param_m2b_a_y.get()) > FLT_EPSILON);
+
+		if (!any_axis || (fabsf(_param_m2b_a_r.get()) > FLT_EPSILON)) {
+			attitude.q[0] = (profile == M2B_PROFILE_NAN) ? NAN : INFINITY;
+		}
+
+		if (fabsf(_param_m2b_a_p.get()) > FLT_EPSILON) {
+			attitude.q[1] = (profile == M2B_PROFILE_NAN) ? NAN : INFINITY;
+		}
+
+		if (fabsf(_param_m2b_a_y.get()) > FLT_EPSILON) {
+			attitude.q[2] = (profile == M2B_PROFILE_NAN) ? NAN : INFINITY;
+		}
+
+		if (!any_axis) {
+			attitude.q[1] = (profile == M2B_PROFILE_NAN) ? NAN : INFINITY;
+			attitude.q[2] = (profile == M2B_PROFILE_NAN) ? NAN : INFINITY;
+			attitude.q[3] = (profile == M2B_PROFILE_NAN) ? NAN : INFINITY;
+		}
+	}
+}
