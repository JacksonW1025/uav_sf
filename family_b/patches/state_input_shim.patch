+namespace
+{
+static constexpr int M2B_PROFILE_DELAY = 1;
+static constexpr int M2B_PROFILE_BIAS = 2;
+static constexpr int M2B_PROFILE_NOISE = 3;
+static constexpr int M2B_PROFILE_NAN = 4;
+static constexpr int M2B_PROFILE_INF = 5;
+
+bool m2bShimActive(const bool enabled, const float start_s, const float end_s, const hrt_abstime now)
+{
+	if (!enabled) {
+		return false;
+	}
+
+	const float now_s = static_cast<float>(now) * 1e-6f;
+	return (now_s >= start_s) && ((end_s <= 0.f) || (now_s <= end_s));
+}
+
+bool m2bAxisSelected(const float x, const float y, const float z, const int axis)
+{
+	const bool any_axis = (fabsf(x) > FLT_EPSILON) || (fabsf(y) > FLT_EPSILON) || (fabsf(z) > FLT_EPSILON);
+
+	if (!any_axis) {
+		return true;
+	}
+
+	const float values[3] {x, y, z};
+	return fabsf(values[axis]) > FLT_EPSILON;
+}
+
+float m2bNoise(uint32_t &state, const int32_t seed)
+{
+	if (state == 0) {
+		state = static_cast<uint32_t>(seed) ^ 0x9e3779b9u;
+	}
+
+	state = 1664525u * state + 1013904223u;
+	const float uniform_0_1 = static_cast<float>((state >> 8) & 0x00ffffffu) * (1.f / 16777216.f);
+	return 2.f * uniform_0_1 - 1.f;
+}
+
